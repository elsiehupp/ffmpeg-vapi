[Flags]
[CCode (cheader_filename="subprojects/ffmpeg/libavformat/asf.h")]
public enum ASFPacketFlags {
    [CCode (cname="ASF_PACKET_FLAG_ERROR_CORRECTION_PRESENT")]
    ERROR_CORRECTION_PRESENT; // 1000 0000
}

/***********************************************************
//   ASF data packet structure
//   =========================
//
//
//  -----------------------------------
// | Error Correction Data             |  Optional
//  -----------------------------------
// | Payload Parsing Information (PPI) |
//  -----------------------------------
// | Payload Data                      |
//  -----------------------------------
// | Padding Data                      |
//  -----------------------------------
***********************************************************/


/***********************************************************
@brief PPI_FLAG - Payload parsing information flags
***********************************************************/
[CCode (cprefix="ASF_PPI_FLAG_",cheader_filename="subprojects/ffmpeg/libavformat/asf.h")]
public enum ASFPayloadParsingFlags {
    MULTIPLE_PAYLOADS_PRESENT,

    SEQUENCE_FIELD_IS_BYTE, // 0000 0010
    SEQUENCE_FIELD_IS_WORD, // 0000 0100
    SEQUENCE_FIELD_IS_DWORD, // 0000 0110

    [CCode (cname="ASF_PPI_FLAG_MASK_SEQUENCE_FIELD_SIZE")]
    SEQUENCE_FIELD_SIZE_MASK, // 0000 0110

    PADDING_LENGTH_FIELD_IS_BYTE, // 0000 1000
    PADDING_LENGTH_FIELD_IS_WORD, // 0001 0000
    PADDING_LENGTH_FIELD_IS_DWORD, // 0001 1000

    [CCode (cname="ASF_PPI_FLAG_MASK_PADDING_LENGTH_FIELD_SIZE")]
    PADDING_LENGTH_FIELD_SIZE_MASK, // 0001 1000

    PACKET_LENGTH_FIELD_IS_BYTE, // 0010 0000
    PACKET_LENGTH_FIELD_IS_WORD, // 0100 0000
    PACKET_LENGTH_FIELD_IS_DWORD, // 0110 0000

    [CCode (cname="ASF_PPI_FLAG_MASK_PACKET_LENGTH_FIELD_SIZE")]
    PACKET_LENGTH_FIELD_SIZE_MASK; // 0110 0000
}

/***********************************************************
@brief Payload flags
***********************************************************/
[CCode (cprefix="ASF_PL_FLAG_",cheader_filename="subprojects/ffmpeg/libavformat/asf.h")]
public enum ASFPayloadFlags {
    REPLICATED_DATA_LENGTH_FIELD_IS_BYTE, // 0000 0001
    REPLICATED_DATA_LENGTH_FIELD_IS_WORD, // 0000 0010
    REPLICATED_DATA_LENGTH_FIELD_IS_DWORD, // 0000 0011

    [CCode (cname="ASF_PL_FLAG_MASK_REPLICATED_DATA_LENGTH_FIELD_SIZE")]
    REPLICATED_DATA_LENGTH_FIELD_SIZE_MASK, // 0000 0011

    OFFSET_INTO_MEDIA_OBJECT_LENGTH_FIELD_IS_BYTE, // 0000 0100
    OFFSET_INTO_MEDIA_OBJECT_LENGTH_FIELD_IS_WORD, // 0000 1000
    OFFSET_INTO_MEDIA_OBJECT_LENGTH_FIELD_IS_DWORD, // 0000 1100

    [CCode (cname="ASF_PL_FLAG_MASK_OFFSET_INTO_MEDIA_OBJECT_LENGTH_FIELD_SIZE")]
    OFFSET_INTO_MEDIA_OBJECT_LENGTH_FIELD_SIZE_MASK, // 0000 1100

    MEDIA_OBJECT_NUMBER_LENGTH_FIELD_IS_BYTE, // 0001 0000
    MEDIA_OBJECT_NUMBER_LENGTH_FIELD_IS_WORD, // 0010 0000
    MEDIA_OBJECT_NUMBER_LENGTH_FIELD_IS_DWORD, // 0011 0000

    [CCode (cname="ASF_PL_FLAG_MASK_MEDIA_OBJECT_NUMBER_LENGTH_FIELD_SIZE")]
    MEDIA_OBJECT_NUMBER_LENGTH_FIELD_SIZE_MASK, // 0011 0000

    STREAM_NUMBER_LENGTH_FIELD_IS_BYTE, // 0100 0000

    [CCode (cname="ASF_PL_FLAG_MASK_STREAM_NUMBER_LENGTH_FIELD_SIZE")]
    STREAM_NUMBER_LENGTH_FIELD_SIZE_MASK, // 1100 0000

    PAYLOAD_LENGTH_FIELD_IS_BYTE, // 0100 0000
    PAYLOAD_LENGTH_FIELD_IS_WORD, // 1000 0000

    [CCode (cname="ASF_PL_FLAG_MASK_PAYLOAD_LENGTH_FIELD_SIZE")]
    PAYLOAD_LENGTH_FIELD_SIZE_MASK, // 1100 0000

    KEY_FRAME; // 1000 0000
}

} // namespace LibAVFormat
