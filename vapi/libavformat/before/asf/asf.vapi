namespace LibAVFormat {

[CCode (cname="enum ASFDataType",cprefix="ASF_",cheader_filename="subprojects/ffmpeg/libavformat/asf.h")]
public enum ASFDataType {
    UNICODE,
    BYTE_ARRAY,
    BOOL,
    DWORD,
    QWORD,
    WORD,
    GUID;
}

[CCode (cname="struct ASFMainHeader",cheader_filename="subprojects/ffmpeg/libavformat/asf.h")]
[Compact]
public class ASFMainHeader {
    /***********************************************************
    @brief Generated by client computer
    ***********************************************************/
    [CCode (cname="")]
    ff_asf_guid guid;

    /***********************************************************
    @brief In bytes
    (invalid if broadcasting)
    ***********************************************************/
    [CCode (cname="")]
    public uint64 file_size;

    /***********************************************************
    @brief Time of creation, in 100-nanosecond units since 1.1.1601
    (invalid if broadcasting)
    ***********************************************************/
    [CCode (cname="")]
    public uint64 create_time;

    /***********************************************************
    @brief Play time, in 100-nanosecond units
    (invalid if broadcasting)
    ***********************************************************/
    [CCode (cname="")]
    public uint64 play_time;

    /***********************************************************
    @brief Time to send file, in 100-nanosecond units
    (invalid if broadcasting) (could be ignored)
    ***********************************************************/
    [CCode (cname="")]
    public uint64 send_time;

    /***********************************************************
    @brief Timestamp of the first packet, in milliseconds
    if nonzero - subtract from time
    ***********************************************************/
    [CCode (cname="")]
    public uint32 preroll;

    /***********************************************************
    @brief Preroll is 64 bits - but let's just ignore it
    ***********************************************************/
    [CCode (cname="")]
    public uint32 ignore;

    [Flags]
    public enum Flags { // uint32
        BROADCAST = 0x1,
        SEEKABLE = 0x2;
    }

    /***********************************************************
    0x01 - broadcast
    0x02 - seekable
    rest is reserved should be 0
    ***********************************************************/
    [CCode (cname="")]
    public Flags flags;

    /***********************************************************
    @brief Size of a data packet
    (invalid if broadcasting)
    ***********************************************************/
    [CCode (cname="")]
    public uint32 min_pktsize;

    /***********************************************************
    @brief Shall be the same as for min_pktsize
    (invalid if broadcasting)
    ***********************************************************/
    [CCode (cname="")]
    public uint32 max_pktsize;

    /***********************************************************
    @brief Bandwidth of stream in bps
    should be the sum of bitrates of the
    individual media streams
    ***********************************************************/
    [CCode (cname="")]
    public uint32 max_bitrate;
}


[CCode (cname="struct ASFIndex",cheader_filename="subprojects/ffmpeg/libavformat/asf.h")]
[Compact]
public class ASFIndex {
    [CCode (cname="")]
    public uint32 packet_number;

    [CCode (cname="")]
    public uint16 packet_count;

    [CCode (cname="")]
    public uint64 send_time;

    [CCode (cname="")]
    public uint64 offset;
}

