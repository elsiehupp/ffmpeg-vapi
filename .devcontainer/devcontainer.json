// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "elementary OS Circe based on Ubuntu Resolute",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:resolute",

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "apt-get update && apt-get -y install --no-install-recommends gpg-agent software-properties-common git && add-apt-repository -u -y ppa:elementary-os/os-patches && add-apt-repository -u -y ppa:elementary-os/stable && apt-get install -y --no-install-recommends elementary-os-overlay && apt-get update && apt-get -y dist-upgrade && apt-get install --no-install-recommends -y elementary-sdk elementary-icon-theme vala-language-server && apt-get -y autoremove && apt-get autoclean && rm -rf /var/lib/apt/lists/*",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	"remoteUser": "root"
}
